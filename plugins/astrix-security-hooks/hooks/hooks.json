{
  "PreToolUse": [
    {
      "description": "Block dangerous bash commands before execution",
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-bash.sh",
          "timeout": 5000
        }
      ]
    },
    {
      "description": "Audit all file write operations",
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-write.sh",
          "timeout": 5000
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "description": "Scan prompts for secrets before Claude processes them",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/prompt-scan.sh",
          "timeout": 3000
        }
      ]
    }
  ],
  "ConfigChange": [
    {
      "description": "Audit all configuration changes",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/config-audit.sh",
          "timeout": 3000
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "description": "Log session start for audit trail",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
          "timeout": 3000
        }
      ]
    }
  ]
}
